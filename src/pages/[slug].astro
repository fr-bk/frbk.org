---
import BaseLayout from "../layouts/BaseLayout.astro";
import { PortableText } from "astro-portabletext";
import { loadQuery, urlFor } from "../lib/sanity.js";
import { sideBySlugQuery } from "../lib/queries.js";

const { slug } = Astro.params;
const side = await loadQuery(sideBySlugQuery, { slug });

if (!side) {
  Astro.response.status = 404;
}

const heroImage = side?.heroImageRef
  ? urlFor(side.heroImageRef).width(1600).url()
  : "/img/hero-fotballbane.jpg";

const heroPosition = side?.heroPosition ?? "center";
---

<BaseLayout
  title={side?.title ?? "Sida finst ikkje"}
  heroImage={heroImage}
  heroPosition={heroPosition}
>
  <article class="prose">
    {
      side ? (
        <>
          <h1>{side.title}</h1>
          {side.body && <PortableText value={side.body} />}
        </>
      ) : (
        <>
          <h1>Sida finst ikkje</h1>
          <p>Vi fann ikkje sida du prøvde å opne.</p>
        </>
      )
    }
  </article>
</BaseLayout>
